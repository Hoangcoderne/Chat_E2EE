{
  "name": "chat_e2ee",
  "version": "1.0.0",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --runInBand --forceExit --testPathPattern=unit",
    "test:integration": "jest --runInBand --forceExit --testPathPattern=integration",
    "test:api": "jest --runInBand --forceExit --testPathPattern=api",
    "test:coverage": "jest --runInBand --forceExit --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "**/src/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/controllers/**/*.js",
      "src/middleware/**/*.js",
      "src/utils/**/*.js"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.0.0",
    "mongoose": "^9.1.5",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.11",
    "supertest": "^7.0.0"
  }
}
